# ==========================================
# EduGen System Environment Variables Template
# (สำหรับผู้พัฒนา: คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง)
# ==========================================

# --- การตั้งค่า AI Provider (Ollama Local vs Cloud API) ---
# ตั้งค่าเป็น true หากต้องการรัน AI แบบ Local ผ่าน Ollama บนเครื่อง (ไม่ต้องใช้ API Key)
USE_OLLAMA=false
OLLAMA_BASE_URL="http://127.0.0.1:11434/v1"

# API Key ของ AI Provider (ใส่คีย์ Google Gemini เช่น AQ.../AIza... หรือคีย์ OpenAI เช่น sk-...)
OPENAI_API_KEY="your_openai_or_gemini_api_key_here"

# (ตัวเลือกเสริมสำหรับ Azure OpenAI Service - หักเงิน $100 Credit ฟรี)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_API_VERSION="2024-06-01"

# --- การตั้งค่า Backend & Firebase ---
FIREBASE_PROJECT_ID="your_firebase_project_id_here"
GOOGLE_APPLICATION_CREDENTIALS="./service-account.json"
# ตัวเลือกใส่ Firebase Credentials เป็น Base64 หรือ String สำหรับขึ้น Cloud
FIREBASE_SERVICE_ACCOUNT_BASE64=""
FIREBASE_SERVICE_ACCOUNT_JSON=""
FRONTEND_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# เปิดใช้ X-User-Id สำหรับ dev โดยไม่ต้อง login (production ต้องเป็น false)
ALLOW_DEMO_AUTH=false

# --- การตั้งค่า Frontend (Next.js) ---
NEXT_PUBLIC_API="http://localhost:8000"
NEXT_PUBLIC_ALLOW_DEMO_AUTH=false

# ข้อมูล Firebase Config สำหรับ Frontend
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_web_api_key_here"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your_firebase_project_id_here"
NEXT_PUBLIC_FIREBASE_APP_ID="your_firebase_web_app_id_here"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""
